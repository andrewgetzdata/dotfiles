{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ]
  },
  "enabledPlugins": {
    "arscontexta@agenticnotetaking": true,
    "dagster-expert@dagster": true,
    "dagster-integrations@dagster": true,
    "dignified-python@dagster": true
  },
  "alwaysThinkingEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "effortLevel": "medium",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Bottle.aiff"
          }
        ]
      }
    ]
  }
}
